<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Ocean View Resort</display-name>

    <!-- Welcome -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ===== FILTER (RBAC) ===== -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.oceanview.web.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ===== SERVLETS ===== -->
    <servlet>
        <servlet-name>Home</servlet-name>
        <servlet-class>com.oceanview.web.servlet.HomeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Home</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>Login</servlet-name>
        <servlet-class>com.oceanview.web.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Login</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>Logout</servlet-name>
        <servlet-class>com.oceanview.web.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Logout</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReceptionistDashboard</servlet-name>
        <servlet-class>com.oceanview.web.servlet.ReceptionistDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReceptionistDashboard</servlet-name>
        <url-pattern>/receptionist</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminDashboard</servlet-name>
        <servlet-class>com.oceanview.web.servlet.AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboard</servlet-name>
        <url-pattern>/admin</url-pattern>
    </servlet-mapping>

    <!-- Reservations -->
    <servlet>
        <servlet-name>ReservationAdd</servlet-name>
        <servlet-class>com.oceanview.web.servlet.ReservationAddServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReservationAdd</servlet-name>
        <url-pattern>/receptionist/reservations/add</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReservationView</servlet-name>
        <servlet-class>com.oceanview.web.servlet.ReservationViewServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReservationView</servlet-name>
        <url-pattern>/receptionist/reservations/view</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReservationModify</servlet-name>
        <servlet-class>com.oceanview.web.servlet.ReservationModifyServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReservationModify</servlet-name>
        <url-pattern>/receptionist/reservations/modify</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReservationCancel</servlet-name>
        <servlet-class>com.oceanview.web.servlet.ReservationCancelServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReservationCancel</servlet-name>
        <url-pattern>/receptionist/reservations/cancel</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReservationStatus</servlet-name>
        <servlet-class>com.oceanview.web.servlet.ReservationStatusServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReservationStatus</servlet-name>
        <url-pattern>/receptionist/reservations/status</url-pattern>
    </servlet-mapping>

    <!-- Billing -->
    <servlet>
        <servlet-name>Bill</servlet-name>
        <servlet-class>com.oceanview.web.servlet.BillServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Bill</servlet-name>
        <url-pattern>/receptionist/bill</url-pattern>
    </servlet-mapping>

    <!-- Help & Reports -->
    <servlet>
        <servlet-name>Help</servlet-name>
        <servlet-class>com.oceanview.web.servlet.HelpServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Help</servlet-name>
        <url-pattern>/help</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>Reports</servlet-name>
        <servlet-class>com.oceanview.web.servlet.ReportsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Reports</servlet-name>
        <url-pattern>/admin/reports</url-pattern>
    </servlet-mapping>

    <!-- ===== ADMIN USER MANAGEMENT ===== -->
    <servlet>
        <servlet-name>UserManage</servlet-name>
        <servlet-class>com.oceanview.web.servlet.admin.UserManageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserManage</servlet-name>
        <url-pattern>/admin/users</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UserCreate</servlet-name>
        <servlet-class>com.oceanview.web.servlet.admin.UserCreateServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserCreate</servlet-name>
        <url-pattern>/admin/users/create</url-pattern>
    </servlet-mapping>


    <!-- ===== JSON APIs ===== -->
    <servlet>
        <servlet-name>ReservationApi</servlet-name>
        <servlet-class>com.oceanview.web.api.ReservationApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReservationApi</servlet-name>
        <url-pattern>/api/reservation</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GuestByContactApi</servlet-name>
        <servlet-class>com.oceanview.web.api.GuestByContactApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GuestByContactApi</servlet-name>
        <url-pattern>/api/guestByContact</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RevenueApi</servlet-name>
        <servlet-class>com.oceanview.web.api.RevenueApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RevenueApi</servlet-name>
        <url-pattern>/api/revenue</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>GuestSearchApi</servlet-name>
        <servlet-class>com.oceanview.web.api.GuestSearchApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GuestSearchApi</servlet-name>
        <url-pattern>/api/guestSearch</url-pattern>
    </servlet-mapping>

    <!-- Available Rooms API -->
    <servlet>
        <servlet-name>AvailableRoomsApi</servlet-name>
        <servlet-class>com.oceanview.web.api.AvailableRoomsApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AvailableRoomsApi</servlet-name>
        <url-pattern>/api/availableRooms</url-pattern>
    </servlet-mapping>

    <!-- Daily Income API -->
    <servlet>
        <servlet-name>DailyIncomeApi</servlet-name>
        <servlet-class>com.oceanview.web.api.DailyIncomeApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DailyIncomeApi</servlet-name>
        <url-pattern>/api/dailyIncome</url-pattern>
    </servlet-mapping>


    <!-- ===== ADMIN ROOM TYPES ===== -->
    <servlet>
        <servlet-name>AdminRoomTypes</servlet-name>
        <servlet-class>com.oceanview.web.servlet.admin.AdminRoomTypesServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminRoomTypes</servlet-name>
        <url-pattern>/admin/roomtypes</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminRoomTypeEdit</servlet-name>
        <servlet-class>com.oceanview.web.servlet.admin.AdminRoomTypeEditServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminRoomTypeEdit</servlet-name>
        <url-pattern>/admin/roomtypes/edit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminRoomTypeToggle</servlet-name>
        <servlet-class>com.oceanview.web.servlet.admin.AdminRoomTypeToggleServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminRoomTypeToggle</servlet-name>
        <url-pattern>/admin/roomtypes/toggle</url-pattern>
    </servlet-mapping>

    <!-- ===== ADMIN ROOMS ===== -->
    <servlet>
        <servlet-name>AdminRooms</servlet-name>
        <servlet-class>com.oceanview.web.servlet.admin.AdminRoomsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminRooms</servlet-name>
        <url-pattern>/admin/rooms</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminRoomToggle</servlet-name>
        <servlet-class>com.oceanview.web.servlet.admin.AdminRoomToggleServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminRoomToggle</servlet-name>
        <url-pattern>/admin/rooms/toggle</url-pattern>
    </servlet-mapping>

    <!-- ===== ADMIN RATES ===== -->
    <servlet>
        <servlet-name>AdminRates</servlet-name>
        <servlet-class>com.oceanview.web.servlet.admin.AdminRatesServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminRates</servlet-name>
        <url-pattern>/admin/rates</url-pattern>
    </servlet-mapping>

    <!-- ===== ADMIN SERVICES ===== -->
    <servlet>
        <servlet-name>AdminServices</servlet-name>
        <servlet-class>com.oceanview.web.servlet.admin.AdminServicesServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminServices</servlet-name>
        <url-pattern>/admin/services</url-pattern>
    </servlet-mapping>

</web-app>