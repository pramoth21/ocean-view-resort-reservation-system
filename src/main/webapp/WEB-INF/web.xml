<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Ocean View Resort Reservation System</display-name>

    <welcome-file-list>
        <welcome-file>home</welcome-file>
    </welcome-file-list>

    <!-- ===================== SERVLETS ===================== -->

    <servlet>
        <servlet-name>HomeServlet</servlet-name>
        <servlet-class>com.oceanview.web.servlet.HomeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HomeServlet</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>HelpServlet</servlet-name>
        <servlet-class>com.oceanview.web.servlet.HelpServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HelpServlet</servlet-name>
        <url-pattern>/help</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.oceanview.web.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.oceanview.web.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- Receptionist -->
    <servlet>
        <servlet-name>ReceptionistDashboardServlet</servlet-name>
        <servlet-class>com.oceanview.web.servlet.ReceptionistDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReceptionistDashboardServlet</servlet-name>
        <url-pattern>/receptionist</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReservationAddServlet</servlet-name>
        <servlet-class>com.oceanview.web.servlet.ReservationAddServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReservationAddServlet</servlet-name>
        <url-pattern>/receptionist/reservation/add</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReservationModifyServlet</servlet-name>
        <servlet-class>com.oceanview.web.servlet.ReservationModifyServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReservationModifyServlet</servlet-name>
        <url-pattern>/receptionist/reservation/modify</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReservationCancelServlet</servlet-name>
        <servlet-class>com.oceanview.web.servlet.ReservationCancelServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReservationCancelServlet</servlet-name>
        <url-pattern>/receptionist/reservation/cancel</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReservationViewServlet</servlet-name>
        <servlet-class>com.oceanview.web.servlet.ReservationViewServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReservationViewServlet</servlet-name>
        <url-pattern>/receptionist/reservation/view</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BillServlet</servlet-name>
        <servlet-class>com.oceanview.web.servlet.BillServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BillServlet</servlet-name>
        <url-pattern>/receptionist/bill</url-pattern>
    </servlet-mapping>

    <!-- Admin -->
    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>com.oceanview.web.servlet.AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/admin</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReportsServlet</servlet-name>
        <servlet-class>com.oceanview.web.servlet.ReportsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReportsServlet</servlet-name>
        <url-pattern>/admin/reports</url-pattern>
    </servlet-mapping>

    <!-- APIs (Distributed Web Services) -->
    <servlet>
        <servlet-name>GuestByContactApiServlet</servlet-name>
        <servlet-class>com.oceanview.web.api.GuestByContactApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GuestByContactApiServlet</servlet-name>
        <url-pattern>/api/guest</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReservationApiServlet</servlet-name>
        <servlet-class>com.oceanview.web.api.ReservationApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReservationApiServlet</servlet-name>
        <url-pattern>/api/reservation</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RevenueApiServlet</servlet-name>
        <servlet-class>com.oceanview.web.api.RevenueApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RevenueApiServlet</servlet-name>
        <url-pattern>/api/revenue</url-pattern>
    </servlet-mapping>

    <!-- ===================== FILTER ===================== -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.oceanview.web.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

</web-app>